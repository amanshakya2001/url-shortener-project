<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>URL Shortener — Log in</title>

  <!-- Bootstrap CSS (CDN) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root { --brand: #0d6efd; }
    body { background: #f4f6fb; min-height: 100vh; display: flex; flex-direction: column; }
    .brand { font-weight: 700; letter-spacing: 0.4px; }
    .card { border: 0; border-radius: 1rem; }
    .form-floating > input { height: 3.6rem; }
    .helper { color: #6c757d; }
    .chip { background: #e7f1ff; color: #0b5ed7; border-radius: 999px; padding: .25rem .75rem; }
    .hero { padding: 3.5rem 1rem; }
    @media(min-width: 992px){ .hero { padding: 5rem 0; } }
    .toggle-btn { height: 2rem; line-height: 1; padding: .25rem .5rem; }
    .has-toggle .form-control { padding-right: 3.5rem; }
    .form-floating .toggle-btn { z-index: 2; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg bg-white shadow-sm">
    <div class="container">
      <a class="navbar-brand brand d-flex align-items-center gap-2" href="#">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="24" height="24" rx="5" fill="var(--brand)"></rect>
          <path d="M8 12h8" stroke="white" stroke-width="1.5" stroke-linecap="round"></path>
          <path d="M8 8h8" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.8"></path>
        </svg>
        <span>URL Shortener</span>
      </a>
      <div class="ms-auto d-flex align-items-center gap-2">
        <% if (locals.email) { %>
          <span class="chip small"><%= locals.email %></span>
          <a href="/logout" class="btn btn-sm btn-outline-secondary">Logout</a>
        <% } else { %>
          <a href="/login" class="btn btn-sm btn-outline-secondary">Login</a>
          <a href="/signup" class="btn btn-sm btn-primary">Sign up</a>
        <% } %>
      </div>
    </div>
  </nav>

  <main class="container flex-grow-1">
    <section class="row justify-content-center hero">
      <div class="col-12 col-md-10 col-lg-8">
        <div class="row g-4">
          <div class="col-md-6 d-flex align-items-center">
            <div>
              <h1 class="h3 mb-2">Create your free account</h1>
              <p class="text-muted mb-4">Sign up to shorten, customize and track all your links from one dashboard.</p>

              <ul class="list-unstyled small text-muted">
                <li>• Unlimited short links</li>
                <li>• Custom aliases</li>
                <li>• Real-time analytics</li>
              </ul>
            </div>
          </div>

          <div class="col-md-6">
            <div class="card shadow-sm">
              <div class="card-body p-4">
                <div id="alert" class="alert d-none" role="alert" aria-live="polite"></div>

                <form id="loginForm" novalidate>
                  <div class="form-floating mb-3">
                    <input id="email" name="email" type="email" class="form-control" placeholder="name@example.com" required>
                    <label for="email">Email address</label>
                    <div class="invalid-feedback">Please enter a valid email.</div>
                  </div>

                  <div class="form-floating mb-3 position-relative has-toggle">
                    <input id="password" name="password" type="password" class="form-control" placeholder="Password" minlength="6" required>
                    <label for="password">Password</label>
                    <button type="button" id="togglePwd" class="btn btn-sm btn-outline-secondary toggle-btn position-absolute top-50 end-0 translate-middle-y me-2" aria-label="Toggle password visibility">Show</button>
                    <div class="invalid-feedback">Please enter your password (min 6 characters).</div>
                  </div>

                  <div class="d-grid">
                    <button id="loginbtn" class="btn btn-primary" type="submit">
                      <span id="btnText">Log in</span>
                      <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                    </button>
                  </div>
                </form>

                <div class="text-center small helper mt-3">Don't have an account? <a href="/signup">Sign up</a></div>
              </div>
            </div>

            <div class="mt-3 text-center small text-muted">
              <span class="short-link">example.app/abcd12</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="bg-white border-top py-3 mt-auto">
    <div class="container text-center small text-muted">© <span id="year"></span> URL Shortener — All rights reserved.</div>
  </footer>

  <!-- Bootstrap JS + Popper (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Set footer year if present
    const _yEl = document.getElementById('year');
    if (_yEl) _yEl.textContent = new Date().getFullYear();

    const $ = (id) => document.getElementById(id);
    const form = $("loginForm");
    const email = $("email");
    const password = $("password");
    const loginbtn = $("loginbtn");
    const btnText = $("btnText");
    const btnSpinner = $("btnSpinner");
    const alertBox = $("alert");
    const togglePwd = $("togglePwd");

    function showAlert(message, type = 'info'){
      alertBox.className = `alert alert-${type}`;
      alertBox.textContent = message;
      alertBox.classList.remove('d-none');
      alertBox.focus();
    }

    togglePwd.addEventListener('click', () => {
      const isPass = password.type === 'password';
      password.type = isPass ? 'text' : 'password';
      togglePwd.textContent = isPass ? 'Hide' : 'Show';
      togglePwd.setAttribute('aria-pressed', isPass ? 'true' : 'false');
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.classList.add('was-validated');
        return;
      }

      loginbtn.disabled = true;
      btnSpinner.classList.remove('d-none');

      try {
        const response = await fetch('/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email.value.trim(), password: password.value })
        });
        const data = await response.json().catch(() => ({}));
        if (response.ok) {
          const target = data.redirect || '/';
          window.location.href = target;
        } else {
          showAlert(data.message || 'Invalid credentials. Please try again.', 'danger');
        }
      } catch (err) {
        console.error(err);
        showAlert('Network error. Please try again.', 'danger');
      } finally {
        loginbtn.disabled = false;
        btnSpinner.classList.add('d-none');
      }
    });
  </script>
</body>
</html>
