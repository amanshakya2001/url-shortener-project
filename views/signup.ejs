<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>URL Shortener — Sign up</title>
  <link rel="stylesheet" href="/css/app.css">
  <script src="/js/app.js"></script>
</head>
<body>

<header class="nav">
  <div class="nav-inner">
    <a class="brand" href="/">
      <span class="brand-logo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </span>
      <span>Shortlink</span>
    </a>
    <div class="nav-actions">
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <svg class="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <a href="/login" class="btn btn-secondary btn-sm">Log in</a>
    </div>
  </div>
</header>

<main class="container">
  <section class="auth-wrap">
    <div class="auth-hero">
      <h1>Create your <span class="gradient-text">free</span> account.</h1>
      <p>Sign up to start shortening URLs and tracking clicks across all your links.</p>
      <ul class="feature-list">
        <li><span class="check"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> Unlimited short links</li>
        <li><span class="check"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> Real-time click analytics</li>
        <li><span class="check"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> No credit card. Free forever.</li>
      </ul>
    </div>

    <div class="card">
      <div class="card-body">
        <h2 class="card-title">Sign up</h2>
        <p class="card-subtitle">Takes less than a minute.</p>

        <form id="signupForm" novalidate>
          <div class="field">
            <label class="field-label" for="fullname">Full name</label>
            <input id="fullname" name="fullname" type="text" class="input" placeholder="Jane Doe" required autocomplete="name">
            <span class="field-error hidden" id="nameError">Please enter your full name.</span>
          </div>

          <div class="field">
            <label class="field-label" for="email">Email address</label>
            <input id="email" name="email" type="email" class="input" placeholder="name@example.com" required autocomplete="email">
            <span class="field-error hidden" id="emailError">Please enter a valid email address.</span>
          </div>

          <div class="field">
            <label class="field-label" for="password">Password</label>
            <div class="input-wrap">
              <input id="password" name="password" type="password" class="input" placeholder="At least 6 characters" minlength="6" required autocomplete="new-password">
              <span class="input-suffix">
                <button type="button" class="btn btn-ghost btn-sm" id="togglePwd" aria-label="Toggle password visibility">Show</button>
              </span>
            </div>
            <span class="field-help">Use 6+ characters with a mix of letters, numbers & symbols for stronger security.</span>
            <span class="field-error hidden" id="passwordError">Password must be at least 6 characters.</span>
          </div>

          <button id="signupbtn" class="btn btn-primary btn-block btn-lg" type="submit">
            <span id="btnText">Create account</span>
            <span id="btnSpinner" class="spinner hidden"></span>
          </button>
        </form>

        <hr>
        <div class="text-center small muted">Already have an account? <a href="/login">Log in</a></div>
      </div>
    </div>
  </section>
</main>

<footer class="footer">© <span id="year"></span> Shortlink — built with Express + MongoDB.</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  const form = $('#signupForm');
  const fullname = $('#fullname');
  const email = $('#email');
  const password = $('#password');
  const nameError = $('#nameError');
  const emailError = $('#emailError');
  const passwordError = $('#passwordError');
  const signupbtn = $('#signupbtn');
  const btnSpinner = $('#btnSpinner');
  const togglePwd = $('#togglePwd');

  togglePwd.addEventListener('click', () => {
    const isPass = password.type === 'password';
    password.type = isPass ? 'text' : 'password';
    togglePwd.textContent = isPass ? 'Hide' : 'Show';
  });

  function validate() {
    let ok = true;
    [fullname, email, password].forEach(i => i.classList.remove('is-invalid'));
    [nameError, emailError, passwordError].forEach(e => e.classList.add('hidden'));

    if (!fullname.value.trim()) { fullname.classList.add('is-invalid'); nameError.classList.remove('hidden'); ok = false; }
    if (!email.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) {
      email.classList.add('is-invalid'); emailError.classList.remove('hidden'); ok = false;
    }
    if (!password.value || password.value.length < 6) {
      password.classList.add('is-invalid'); passwordError.classList.remove('hidden'); ok = false;
    }
    return ok;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validate()) return;

    signupbtn.disabled = true;
    btnSpinner.classList.remove('hidden');

    try {
      const res = await fetch('/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fullname: fullname.value.trim(),
          email: email.value.trim(),
          password: password.value
        })
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        toast.success(data.message || 'Account created! Redirecting…', 1500);
        setTimeout(() => { window.location.href = '/'; }, 600);
      } else {
        toast.error(data.error || 'Could not create account.');
      }
    } catch (err) {
      toast.error('Network error. Please try again.');
    } finally {
      signupbtn.disabled = false;
      btnSpinner.classList.add('hidden');
    }
  });
</script>

</body>
</html>
