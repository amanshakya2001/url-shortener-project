<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>URL Shortener — Sign up</title>
  <meta name="description" content="Sign up to create and manage your short URLs quickly and securely.">

  <!-- Bootstrap CSS (CDN) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root{--brand:#0d6efd}
    body{background:#f4f6fb;min-height:100vh;display:flex;flex-direction:column}
    .brand{font-weight:700;letter-spacing:.4px}
    .card{border:0;border-radius:1rem}
    .short-link{font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,"Roboto Mono",monospace}
    .form-floating > input{height:3.6rem}
    .hero{padding:3.5rem 1rem}
    @media(min-width:992px){.hero{padding:5rem 0}}
    .chip{background:#e7f1ff;color:#0b5ed7;border-radius:999px;padding:.25rem .75rem}
    .toggle-btn{height:2rem;line-height:1;padding:.25rem .5rem}
    .has-toggle .form-control{padding-right:3.5rem}
    .form-floating .toggle-btn{z-index:2}
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg bg-white shadow-sm">
    <div class="container">
      <a class="navbar-brand brand d-flex align-items-center gap-2" href="#">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="24" height="24" rx="5" fill="var(--brand)"></rect>
          <path d="M8 12h8" stroke="white" stroke-width="1.5" stroke-linecap="round"></path>
          <path d="M8 8h8" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.8"></path>
        </svg>
        <span>URL Shortener</span>
      </a>
      <div class="ms-auto d-flex align-items-center gap-2">
        <% if (locals.email) { %>
          <span class="chip small"><%= email %></span>
          <a href="/logout" class="btn btn-sm btn-outline-secondary">Logout</a>
        <% } else { %>
          <a href="/login" class="btn btn-sm btn-outline-secondary">Login</a>
          <a href="/signup" class="btn btn-sm btn-primary">Sign up</a>
        <% } %>
      </div>
    </div>
  </nav>

  <main class="container flex-grow-1">
    <section class="row justify-content-center hero">
      <div class="col-12 col-md-10 col-lg-8">
        <div class="row g-4">
          <div class="col-md-6 d-flex align-items-center">
            <div>
              <h1 class="h3 mb-2">Create your free account</h1>
              <p class="text-muted mb-4">Sign up to shorten, customize and track all your links from one dashboard.</p>

              <ul class="list-unstyled small text-muted">
                <li>• Unlimited short links</li>
                <li>• Custom aliases</li>
                <li>• Real-time analytics</li>
              </ul>
            </div>
          </div>

          <div class="col-md-6">
            <div class="card shadow-sm">
              <div class="card-body p-4">
                <form id="signupForm" novalidate>

                  <div class="mb-3 form-floating">
                    <input id="fullname" name="fullname" type="text" class="form-control" placeholder="Full name" required aria-describedby="fullnameHelp">
                    <label for="fullname">Full name</label>
                    <div id="fullnameHelp" class="form-text">Enter your full name as you'd like it displayed.</div>
                    <div class="invalid-feedback">Please enter your full name.</div>
                  </div>

                  <div class="mb-3 form-floating">
                    <input id="email" name="email" type="email" class="form-control" placeholder="name@example.com" required aria-describedby="emailHelp">
                    <label for="email">Email address</label>
                    <div id="emailHelp" class="form-text">We'll never share your email. Used for account recovery.</div>
                    <div class="invalid-feedback">Please enter a valid email address.</div>
                  </div>

                  <div class="mb-1 form-floating position-relative has-toggle">
                    <input id="password" name="password" type="password" class="form-control" placeholder="Create password" minlength="8" required aria-describedby="pwdHelp">
                    <label for="password">Password</label>
                    <button type="button" id="togglePwd" class="btn btn-sm btn-outline-secondary toggle-btn position-absolute top-50 end-0 translate-middle-y me-2" aria-label="Toggle password visibility">Show</button>
                    <div class="invalid-feedback">Password must be at least 8 characters.</div>
                  </div>
                  <div id="pwdHelp" class="form-text mb-3">Minimum 8 characters. Use letters, numbers & symbols for stronger security.</div>

                  <div class="d-grid">
                    <button id="signupbtn" class="btn btn-primary" type="submit">
                      <span id="btnText">Create account</span>
                      <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                    </button>
                  </div>

                </form>

                <div id="alert" class="alert mt-3 d-none" role="alert" aria-live="polite"></div>

                <hr>
                <div class="text-center small text-muted">Already have an account? <a href="/login">Log in</a></div>
              </div>
            </div>

            <div class="mt-3 text-center small text-muted">
              <span class="short-link">example.app/abcd12</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="bg-white border-top py-3 mt-auto">
    <div class="container text-center small text-muted">© <span id="year"></span> URL Shortener — All rights reserved.</div>
  </footer>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Small helpers
    const $ = (id) => document.getElementById(id);
    $('year').textContent = new Date().getFullYear();

    const form = $('signupForm');
    const fullname = $('fullname');
    const email = $('email');
    const password = $('password');
    const signupbtn = $('signupbtn');
    const btnText = $('btnText');
    const btnSpinner = $('btnSpinner');
    const alertBox = $('alert');
    const togglePwd = $('togglePwd');

    // Toggle password visibility
    togglePwd.addEventListener('click', () => {
      const isPass = password.type === 'password';
      password.type = isPass ? 'text' : 'password';
      togglePwd.textContent = isPass ? 'Hide' : 'Show';
      togglePwd.setAttribute('aria-pressed', isPass ? 'true' : 'false');
    });

    // Client-side validation and submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // Bootstrap-style validation
      if (!form.checkValidity()) {
        form.classList.add('was-validated');
        return;
      }

      // UI: disable button, show spinner
      signupbtn.disabled = true;
      btnSpinner.classList.remove('d-none');

      try {
        const payload = {
          fullname: fullname.value.trim(),
          email: email.value.trim(),
          password: password.value
        };

        const res = await fetch('/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const data = await res.json().catch(() => ({}));

        if (res.ok) {
          const target = data.redirect || '/';
          window.location.href = target;
        } else {
          const msg = data.message || 'Could not create account. Please try again.';
          showAlert(msg, 'danger');
        }

      } catch (err) {
        console.error(err);
        showAlert('Network error. Please check your connection and try again.', 'danger');
      } finally {
        signupbtn.disabled = false;
        btnSpinner.classList.add('d-none');
      }
    });

    function showAlert(message, type = 'info'){
      alertBox.className = `alert alert-${type} mt-3`;
      alertBox.textContent = message;
      alertBox.classList.remove('d-none');
      alertBox.focus();
    }
  </script>
</body>
</html>
